# Supabase — istemci tarafı (public, RLS ile korunur)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — yalnızca sunucu tarafı (cron/route handler). İSTEMCİYE ASLA SIZDIRMA.
SUPABASE_SERVICE_ROLE_KEY=

# Finnhub (ABD hisse fiyatları) — ücretsiz katman: finnhub.io/register
FINNHUB_API_KEY=

# Vercel Cron'un /api/cron/prices'ı çağırırken gönderdiği gizli anahtar (kendi belirlediğin rastgele bir değer)
CRON_SECRET=
